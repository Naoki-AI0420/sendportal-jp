# ===========================================
# SendPortal 日本語版 環境設定
# ===========================================

# --- アプリケーション基本設定 ---
APP_NAME=SendPortal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

# --- ログ設定 ---
LOG_CHANNEL=stack

# --- データベース設定 ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sendportal
DB_USERNAME=sendportal
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# --- ブロードキャスト・キャッシュ・キュー・セッション ---
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --- Redis設定 ---
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- メール設定（SMTPテスト用） ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS設定（SES利用時） ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=

# --- Pusher設定（リアルタイム通知用） ---
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- SendPortal固有設定 ---
# APIレート制限（リクエスト数,秒数）
SENDPORTAL_THROTTLE_MIDDLEWARE=60,1
# 新規ユーザー登録の許可
SENDPORTAL_REGISTER=false
# パスワードリセット機能の有効化
SENDPORTAL_PASSWORD_RESET=true
