# ===========================================
# アプリケーション基本設定
# ===========================================
APP_NAME=メルマガ管理
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

# ログ設定
LOG_CHANNEL=stack

# ===========================================
# データベース設定
# ===========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sendportal
DB_USERNAME=sendportal
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ===========================================
# キャッシュ・キュー・セッション設定
# ===========================================
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ===========================================
# Redis設定
# ===========================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# メール設定（システム通知用）
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# AWS設定（SES利用時）
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=

# ===========================================
# SendPortal固有設定
# ===========================================
# APIスロットル制限（リクエスト数,分）
SENDPORTAL_THROTTLE_MIDDLEWARE=60,1

# 新規ユーザー登録を許可するか
SENDPORTAL_REGISTER=false

# パスワードリセット機能を有効にするか
SENDPORTAL_PASSWORD_RESET=true

# ===========================================
# Docker設定
# ===========================================
# ホスト側のポート番号
APP_PORT=8080
DB_PORT=3306
